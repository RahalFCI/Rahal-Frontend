{
  "expo": {
    "name": "Rahal",
    "slug": "rahal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rahal",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F6F7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rahal.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F5F6F7"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.rahal.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#755700"
        }
      ],
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Rahal uses your location to find nearby places and verify check-ins."
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "11.20.1"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Rahal uses your photo library only when you choose a profile picture.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "97e86116-c6c2-4b54-909c-0ee4767efb9d"
      }
    },
    "owner": "rahal-app"
  }
}
